# Base URL for the REST API (proxied via nginx in production)
VITE_API_BASE_URL=/api

# Enable MSW mock API (set to 'false' to disable)
VITE_USE_MOCK_API=true

# Azure AD SSO (only needed when VITE_USE_MOCK_API=false)
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_REDIRECT_URI=
VITE_AZURE_API_SCOPE=
